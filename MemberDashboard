import { useState, useEffect } from "react";
import { Button } from "@/components/ui/button";
import { Card } from "@/components/ui/card";
import { trpc } from "@/lib/trpc";
import { useLocation } from "wouter";

export default function MemberDashboard() {
  const [, setLocation] = useLocation();
  const [memberUser, setMemberUser] = useState<any>(null);
  const [bookingForm, setBookingForm] = useState({
    lessonDate: "",
    lessonTime: "10:00",
    platform: "zoom",
    notes: "",
  });
  const [bookings, setBookings] = useState<any[]>([]);
  const [error, setError] = useState("");
  const [success, setSuccess] = useState("");

  useEffect(() => {
    const stored = localStorage.getItem("memberUser");
    if (!stored) {
      setLocation("/member-login");
      return;
    }
    setMemberUser(JSON.parse(stored));
  }, [setLocation]);

  const createBookingMutation = trpc.booking.create.useMutation({
    onSuccess: () => {
      setSuccess("Booking created successfully!");
      setBookingForm({
        lessonDate: "",
        lessonTime: "10:00",
        platform: "zoom",
        notes: "",
      });
      setTimeout(() => setSuccess(""), 3000);
      // Reload bookings
      if (memberUser?.id) {
        fetchBookings();
      }
    },
    onError: (err) => {
      setError(err.message || "Failed to create booking");
    },
  });

  const getBookingsQuery = trpc.booking.getMemberBookings.useQuery(
    { memberId: memberUser?.id || 0 },
    { enabled: !!memberUser?.id }
  );

  const fetchBookings = () => {
    getBookingsQuery.refetch();
  };

  useEffect(() => {
    if (getBookingsQuery.data) {
      setBookings(getBookingsQuery.data);
    }
  }, [getBookingsQuery.data]);

  const handleBookingChange = (e: React.ChangeEvent<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>) => {
    const { name, value } = e.target;
    setBookingForm(prev => ({ ...prev, [name]: value }));
  };

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    setError("");

    if (!bookingForm.lessonDate) {
      setError("Please select a lesson date");
      return;
    }

    if (!memberUser?.id) {
      setError("Member information not found");
      return;
    }

    const dateTime = new Date(`${bookingForm.lessonDate}T${bookingForm.lessonTime}`);

    createBookingMutation.mutate({
      memberId: memberUser.id,
      lessonDate: dateTime,
      platform: bookingForm.platform as "zoom" | "whatsapp" | "telegram" | "signal",
      notes: bookingForm.notes || undefined,
    });
  };

  const handleLogout = () => {
    localStorage.removeItem("memberUser");
    setLocation("/");
  };

  if (!memberUser) {
    return (
      <div className="min-h-screen bg-background text-foreground flex items-center justify-center">
        <p>Loading...</p>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-background text-foreground py-12 px-4">
      <div className="max-w-4xl mx-auto">
        {/* Header */}
        <div className="flex items-center justify-between mb-8">
          <div>
            <h1 className="text-4xl font-bold text-primary">Member Dashboard</h1>
            <p className="text-muted-foreground">Welcome, {memberUser.fullName || memberUser.username}!</p>
          </div>
          <Button
            onClick={handleLogout}
            className="bg-secondary hover:bg-secondary/90 text-foreground"
          >
            Logout
          </Button>
        </div>

        <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
          {/* Booking Form */}
          <Card className="p-8 border-l-4 border-primary">
            <h2 className="text-2xl font-bold text-primary mb-6">Book a Lesson</h2>

            {error && (
              <div className="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                {error}
              </div>
            )}

            {success && (
              <div className="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
                {success}
              </div>
            )}

            <form onSubmit={handleSubmit} className="space-y-4">
              <div>
                <label className="block text-sm font-medium mb-1">Lesson Date</label>
                <input
                  type="date"
                  name="lessonDate"
                  value={bookingForm.lessonDate}
                  onChange={handleBookingChange}
                  className="w-full px-3 py-2 border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                  required
                />
              </div>

              <div>
                <label className="block text-sm font-medium mb-1">Lesson Time</label>
                <input
                  type="time"
                  name="lessonTime"
                  value={bookingForm.lessonTime}
                  onChange={handleBookingChange}
                  className="w-full px-3 py-2 border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                  required
                />
              </div>

              <div>
                <label className="block text-sm font-medium mb-1">Platform</label>
                <select
                  name="platform"
                  value={bookingForm.platform}
                  onChange={handleBookingChange}
                  className="w-full px-3 py-2 border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                >
                  <option value="zoom">Zoom</option>
                  <option value="whatsapp">WhatsApp</option>
                  <option value="telegram">Telegram</option>
                  <option value="signal">Signal</option>
                </select>
              </div>

              <div>
                <label className="block text-sm font-medium mb-1">Notes (Optional)</label>
                <textarea
                  name="notes"
                  value={bookingForm.notes}
                  onChange={handleBookingChange}
                  className="w-full px-3 py-2 border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                  placeholder="Any special requests or topics?"
                  rows={3}
                />
              </div>

              <Button
                type="submit"
                className="w-full bg-primary hover:bg-primary/90 text-primary-foreground font-semibold"
                disabled={createBookingMutation.isPending}
              >
                {createBookingMutation.isPending ? "Booking..." : "Book Lesson"}
              </Button>
            </form>
          </Card>

          {/* Bookings List */}
          <div>
            <h2 className="text-2xl font-bold text-primary mb-6">Your Bookings</h2>
            <div className="space-y-4">
              {bookings.length === 0 ? (
                <Card className="p-6 border-l-4 border-primary text-center">
                  <p className="text-muted-foreground">No bookings yet. Book your first lesson!</p>
                </Card>
              ) : (
                bookings.map((booking) => (
                  <Card key={booking.id} className="p-6 border-l-4 border-primary">
                    <div className="flex items-start justify-between">
                      <div>
                        <p className="font-semibold text-lg">
                          {new Date(booking.lessonDate).toLocaleDateString()} at{" "}
                          {new Date(booking.lessonDate).toLocaleTimeString([], {
                            hour: "2-digit",
                            minute: "2-digit",
                          })}
                        </p>
                        <p className="text-muted-foreground capitalize">Platform: {booking.platform}</p>
                        {booking.notes && (
                          <p className="text-sm text-muted-foreground mt-2">Notes: {booking.notes}</p>
                        )}
                      </div>
                      <span className={`px-3 py-1 rounded-full text-sm font-medium capitalize ${
                        booking.status === "confirmed"
                          ? "bg-green-100 text-green-700"
                          : booking.status === "completed"
                          ? "bg-blue-100 text-blue-700"
                          : "bg-yellow-100 text-yellow-700"
                      }`}>
                        {booking.status}
                      </span>
                    </div>
                  </Card>
                ))
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}
